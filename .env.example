# Local PostgreSQL container
POSTGRES_PASSWORD=context_pilot_local_dev
DB_URL=jdbc:postgresql://127.0.0.1:15432/context_pilot
DB_USERNAME=context_pilot

# Backend upload directory when the backend is started from backend/.
STORAGE_ROOT=../data/uploads
DOCUMENT_MAX_FILE_SIZE=20MB
DOCUMENT_MAX_REQUEST_SIZE=21MB
SERVER_PORT=18080

# Enable model integrations only after supplying backend-only API keys.
SPRING_AI_CHAT_MODEL=deepseek
SPRING_AI_EMBEDDING_MODEL=openai
SPRING_AI_VECTOR_STORE=pgvector
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
